# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Admin security. Required for the backend admin panel.
# Use a strong password; there is no default admin/admin fallback anymore.
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-this-to-a-long-random-password"

# Optional alternative to ADMIN_PASSWORD:
# Use pbkdf2$iterations$salt$hash. Legacy sha256(password) hashes are still accepted.
# ADMIN_PASSWORD_HASH="pbkdf2$210000$SALT$DERIVED_HASH"

# VITE_GEMINI_API_KEY: Used by static Trang thông tin điện tử builds.
# This value is bundled into the browser app, so use a restricted API key.
# GitHub Actions also writes this key to dist/runtime-config.json for runtime fallback.
VITE_GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SMTP Configuration (Optional but required for real automatic email recovery)
# If using Gmail, you can use an App Password (Mật khẩu ứng dụng)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
